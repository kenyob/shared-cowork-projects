# ══════════════════════════════════════════════════════════════════════════════
#  shared-cowork-projects — Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it is in .gitignore by default.
# ══════════════════════════════════════════════════════════════════════════════

# ── Folder setup ──────────────────────────────────────────────────────────────

# The name of your top-level Cowork folder (inside iCloud Drive / your sync folder)
COWORK_FOLDER_NAME=shared-cowork-projects

# Sync method: icloud | dropbox | googledrive | syncthing | manual
SYNC_METHOD=icloud

# ── Claude.ai authentication ──────────────────────────────────────────────────

# Option A — Official API key (preferred, get yours at console.anthropic.com)
ANTHROPIC_API_KEY=

# Option B — Cookie-based auth (fallback if API key not available)
# Your Claude.ai organization ID — find it at: claude.ai → any project URL UUID
CLAUDE_ORG_ID=

# ── iOS / Claude.ai Project Registry ─────────────────────────────────────────
# List each Claude.ai project you want to sync agents.md into.
# Find project IDs at claude.ai/project/<id>
# Format: PROJECT_<N>_NAME and PROJECT_<N>_ID (start from 1, no gaps)

PROJECT_1_NAME=My First Project
PROJECT_1_ID=
PROJECT_1_FOLDER=01-Projects/my-first-project
PROJECT_1_AGENTS_FILE=agents.md

# PROJECT_2_NAME=My Second Project
# PROJECT_2_ID=
# PROJECT_2_FOLDER=02-Areas/my-area
# PROJECT_2_AGENTS_FILE=agents.md

# ── Heartbeat / health check schedule ────────────────────────────────────────
# Cron schedule for this machine's heartbeat.
# Stagger machines so they don't write to iCloud at the same time.
# Machine 1 (primary):  0,30 * * * *   (fires at :00 and :30)
# Machine 2 (laptop):  15,45 * * * *   (fires at :15 and :45)
HEARTBEAT_CRON=0,30 * * * *

# ── Claude auto-memory sync ───────────────────────────────────────────────────
# Path to Claude's local auto-memory folder (the memory/ dir Claude writes to
# during Cowork desktop sessions). This folder is NOT in iCloud by default.
# Setting this enables: python3 scripts/sync.py sync-memory
# which copies memory files into cowork-shared-memory/claude-memory/<MACHINE>/
# so they travel between machines via your sync method.
#
# To find your path: in a Cowork session ask Claude "where is your memory folder?"
# It will return the full path for this machine.
#
# Example (yours will have a different session UUID):
# CLAUDE_MEMORY_PATH=~/Library/Application Support/Claude/local-agent-mode-sessions/.../spaces/.../memory
CLAUDE_MEMORY_PATH=

# ── Optional: Notification thresholds ────────────────────────────────────────
HEARTBEAT_WARN_MINUTES=45
HEARTBEAT_CRIT_MINUTES=120
